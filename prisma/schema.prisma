generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the rhel target is what Vercel's serverless runtime needs.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  wpm       Int
  rawWpm    Int
  accuracy  Float
  duration  Int // seconds
  feeling   String   @default("focused") // calm | focused | tired | frustrated | energized
  notes     String   @default("")
  createdAt DateTime @default(now())

  @@index([date])
}

model Achievement {
  id          String    @id @default(cuid())
  key         String    @unique
  title       String
  description String
  emoji       String
  tone        String    @default("sage") // sage | lavender | blue | card
  unlocked    Boolean   @default(false)
  unlockedAt  DateTime?
}
